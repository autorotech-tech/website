# Docker `agent-api` на VPS: задайте те же значения (или только anon в двух именах):
# SUPABASE_URL=https://swoop.autoro.tech/supabase
# SUPABASE_ANON_KEY=<равен VITE_SUPABASE_ANON_KEY>

# --- Bookmarks Bro / agent-api ---
# UI state (ideas, reminders, карточки KB): таблица bookmarks_bro_workspace_ui после деплоя agent-api.
# VITE_BOOKMARKS_API_KEY=<ключ agent-api из Swoop settings>
# Локальный тест API: AGENT_API_BASE=http://127.0.0.1:8900 npm run bookmarks-bro:api-test
# Оставьте VITE_AGENT_API_BASE не заданным или пустым:
#   • npm run dev → запросы на /api/v1/* проксируются на agent-api (vite.config → 127.0.0.1:8900)
#   • production → тот же хост что и SPA; nginx должен проксировать /api/v1 на agent-api
# Явный URL если фронт и agent-api на разных origin:
# VITE_AGENT_API_BASE=http://localhost:8900
#
# Цель dev-прокси (если agent-api не на 8900):
# VITE_AGENT_API_PROXY_TARGET=http://127.0.0.1:8900

# --- ExpiredDomains.net (Swoop → Settings или env для agent-api) ---
# EXPIREDDOMAINS_USERNAME=
# EXPIREDDOMAINS_PASSWORD=
# EXPIREDDOMAINS_SESSION_COOKIE=
# EXPIREDDOMAINS_API_BASE=https://member.expireddomains.net

# --- SafeDep Cloud (Cursor MCP — блокировка вредоносных npm/pypi перед установкой) ---
# Tenant и ключ: https://app.safedep.io/settings/api-keys
# MCP: https://docs.safedep.io/apps/mcp/overview
# После заполнения: npm run safedep:mcp:configure
# SAFEDEP_CLOUD_TENANT_DOMAIN=your-tenant-domain.safedep.io
# SAFEDEP_CLOUD_API_KEY=sfd_...
# На GitHub Actions те же имена → Repository secrets (см. .github/workflows/safedep-vet.yml).
