# Keep It For Me — local dev env template (copy to .env, never commit .env)

# BB Supabase (staging) — get anon key from operator / VPS (AUTH-SETUP.md §4)
VITE_SUPABASE_URL=https://swoop.autoro.tech/bb-supabase
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_BB_ANON_KEY

# agent-api: empty in dev → Vite proxies /api/v1 to localhost:8900
# VITE_AGENT_API_BASE=
# VITE_AGENT_API_PROXY_TARGET=http://127.0.0.1:8900

# Optional smoke / admin
# VITE_BOOKMARKS_API_KEY=REPLACE_FROM_SWOOP_ADMIN_OR_VPS
