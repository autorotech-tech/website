# agent-api — example env (copy to .env on VPS; never commit .env)

# --- Main Swoop Supabase (operators / legacy routes) ---
SUPABASE_URL=https://swoop.autoro.tech/supabase
SUPABASE_ANON_KEY=REPLACE_WITH_SWOOP_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SWOOP_SERVICE_ROLE_KEY

# --- Keep It For Me / Bookmarks Bro isolated stack ---
# When set, bookmarks routes use BB Auth + BB Postgres only.
BOOKMARKS_SUPABASE_URL=https://swoop.autoro.tech/bb-supabase
BOOKMARKS_SUPABASE_ANON_KEY=REPLACE_WITH_BB_ANON_KEY
BOOKMARKS_PGHOST=supabase-db-bb
BOOKMARKS_PGPORT=5432
BOOKMARKS_PGDATABASE=postgres
BOOKMARKS_PGUSER=postgres
BOOKMARKS_PGPASSWORD=REPLACE_WITH_BB_DB_PASSWORD

# --- LLM (prefer Swoop Admin → Settings; env fallback) ---
# OPENROUTER_API_KEY=
# Default model must include provider prefix, e.g. anthropic/claude-3.7-sonnet

# --- Optional: Bookmarks admin / smoke tests ---
# BOOKMARKS_API_KEY=
