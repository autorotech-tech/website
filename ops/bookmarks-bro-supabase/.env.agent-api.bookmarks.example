# Использовать в .env рядом с website/docker-compose.yml
# Для agent-api: отдельный Auth + отдельный Postgres только для Bookmarks Bro.

# Публичный URL нового Kong (через nginx route /bb-supabase/)
BOOKMARKS_SUPABASE_URL=https://swoop.autoro.tech/bb-supabase
BOOKMARKS_SUPABASE_ANON_KEY=REPLACE_WITH_BOOKMARKS_BRO_ANON_KEY

# Прямой доступ к новой Postgres/Pooler (в изолированной сети)
BOOKMARKS_PGHOST=supabase-db
BOOKMARKS_PGPORT=5432
BOOKMARKS_PGDATABASE=postgres
BOOKMARKS_PGUSER=supabase_admin
BOOKMARKS_PGPASSWORD=REPLACE_WITH_BOOKMARKS_BRO_DB_PASSWORD

